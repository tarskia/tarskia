{
  "name": "@tarskia/frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/build-semantics.mjs && vite",
    "build": "node ../scripts/build-semantics.mjs && tsc -b && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "generate:api": "orval --config orval.config.ts",
    "lint": "biome check --diagnostic-level=error .",
    "format": "biome check --write --unsafe .",
    "validate:schemas": "node ../scripts/build-semantics.mjs && vitest run --run src/semantic/bundled-assets.test.ts src/model/validation/schema.test.ts src/model/validation/schema-module-examples.test.ts src/shell/schema-cookbook.test.ts src/shell/schema-dependency-reference.test.ts",
    "test": "node ../scripts/build-semantics.mjs && vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tarskia/diagram-semantics": "0.0.1",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "orval": "^8.6.2",
    "testcontainers": "^11.14.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
